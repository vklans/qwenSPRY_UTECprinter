# Entorno (development, production)
PRINTWATCH_ENV=development

# Fuente SNMP (api, local_snmp)
PRINTWATCH_SNMP_SOURCE=api

# URL de API SNMP (solo si PRINTWATCH_SNMP_SOURCE=api)
PRINTWATCH_API_URL=http://10.100.120.100:5000

# Ruta a base de datos
PRINTWATCH_DB_PATH=./data/printwatch.db

# Clave secreta para sesiones Flask
SECRET_KEY=cambia_esto_por_una_clave_segura_de_32_caracteres

# Configuración de rate limiting
RATELIMIT_STORAGE_URL=memory://

# Google Drive (opcional)
GDRIVE_ENABLED=false
GDRIVE_FOLDER_ID=
GDRIVE_SERVICE_ACCOUNT_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
